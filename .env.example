# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_BACKEND_URL: The HTTPS endpoint of your Firebase Cloud Function.
# Example: https://us-central1-your-project-id.cloudfunctions.net/removeBackground
FIREBASE_BACKEND_URL=https://us-central1-your-project.cloudfunctions.net/removeBackground
